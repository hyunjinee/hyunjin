---
// 임시 검증 페이지 — scripts/smoke-collections.mjs가 build 산출물을 파싱해 slug 계약을 확인한다
// 파일명에 '_' 접두사를 쓰지 않는 이유: Astro는 pages/ 하위 '_'로 시작하는 경로를 라우트에서 제외한다
// (node_modules/astro/dist/core/util.js isPublicRoute)
import { getCollection, render } from 'astro:content'
// biome-ignore lint/correctness/noUnusedImports: 아래 astro 템플릿(frontmatter 밖)에서 사용 — biome은 .astro 템플릿을 보지 않는다
import Base from '../layouts/Base.astro'
import { entryLocale, entrySlug, findBySlug, postsForLocale } from '../lib/posts'

const rawEntries = await getCollection('blog')
const koRaw = rawEntries.filter((entry) => entryLocale(entry) === 'ko').length
const enRaw = rawEntries.filter((entry) => entryLocale(entry) === 'en').length

const koPosts = await postsForLocale('ko')
const enPosts = await postsForLocale('en')

// en/closed-loop.mdx는 draft: true — findBySlug가 draft를 걸러내면 undefined가 나와야 한다
const draftLookup = await findBySlug('en', 'closed-loop')

// biome-ignore lint/correctness/noUnusedVariables: 아래 astro 템플릿(frontmatter 밖)에서 사용 — biome은 .astro 템플릿을 보지 않는다
const data = {
  ko: { raw: koRaw, slugs: koPosts.map(entrySlug) },
  en: { raw: enRaw, slugs: enPosts.map(entrySlug) },
  draftFilterHolds: draftLookup === undefined,
}

// markdown 파이프라인(rehypeSlug/rehypeAutolinkHeadings/rehypePrismPlus)이 실제로 살아있는지
// 공개 글 1편을 실제 렌더해 확인 — scripts/smoke-collections.mjs가 출력 HTML에서 마커를 grep한다
const renderTarget = await findBySlug('ko', 'understanding-react-rendering')
// biome-ignore lint/correctness/noUnusedVariables: 아래 astro 템플릿(frontmatter 밖)에서 사용 — biome은 .astro 템플릿을 보지 않는다
const { Content } = renderTarget ? await render(renderTarget) : { Content: null }
---

<Base locale="ko" title="Smoke">
  <pre id="smoke-data">{JSON.stringify(data)}</pre>
  {Content && (
    <div id="smoke-render">
      <Content />
    </div>
  )}
</Base>
