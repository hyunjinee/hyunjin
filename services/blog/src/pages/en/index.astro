---
// app/[locale]/page.tsx 이식 (en 분기 — Main 렌더). ko판은 src/pages/index.astro(ResumeHome).
// biome-ignore-all lint/correctness/noUnusedImports: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
// biome-ignore-all lint/correctness/noUnusedVariables: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
import siteMetadata from '../../../data/siteMetadata.js'
import PostList from '../../components/PostList.astro'
import Base from '../../layouts/Base.astro'
import { postsForLocale } from '../../lib/posts'

const posts = await postsForLocale('en')
const canonical = `${siteMetadata.siteUrl}/en`
// page.tsx의 en 분기 metadata는 openGraph를 지정하지 않아 layout.tsx의 기본 og:title/og:description을
// 그대로 물려받는다 — <title>·description(<meta name>)만 'Blog'/'Posts in English'로 바뀌고
// og:*·twitter:*는 사이트 기본값 그대로인 원본의 실제 동작(out/en.html 확인)을 ogTitle/ogDescription으로 재현한다.
const DEFAULT_TITLE = '이현진 (Hyunjin Lee) — Software Engineer'
---

<Base
  title="Blog"
  ogTitle={DEFAULT_TITLE}
  description="Posts in English"
  ogDescription={siteMetadata.description}
  canonical={canonical}
  hreflang={{ ko: siteMetadata.siteUrl, en: canonical, xDefault: canonical }}
  ogUrl={false}
  locale="en"
>
  <PostList posts={posts} />
</Base>
