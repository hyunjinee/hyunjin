---
// app/[locale]/page.tsx(ko 분기) + app/[locale]/ResumeHome.tsx 이식(401줄 정적 마크업).
// next/image(unoptimized)는 <img>로 속성 보존 — fill 프로필 사진은 PostBanner.astro와 동일한
// absolute inset-0 h-full w-full 관용구, 나머지 로고 이미지는 width/height/style 그대로.
// biome-ignore-all lint/correctness/noUnusedImports: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
// biome-ignore-all lint/correctness/noUnusedVariables: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
import siteMetadata from '../../data/siteMetadata.js'
import Link from '../components/Link.astro'
import Base from '../layouts/Base.astro'

type Experience = {
  title: string
  period: string
  role: string
  link?: string
  logos?: { src: string; darkInvert?: boolean; href: string; width: number; height: number }[]
  projects: { name: string; link?: string; bullets: string[] }[]
}

const experiences: Experience[] = [
  {
    title: '카카오 엔터테인먼트',
    period: '2024.07 ~ Now',
    role: 'Frontend Engineer',
    link: '/kakaoent',
    logos: [
      {
        src: '/images/kakaoentertainment/kakaoent.svg',
        darkInvert: true,
        href: 'https://kakaoent.com/',
        width: 57,
        height: 25,
      },
      { src: '/images/kakaoentertainment/berriz_logo.svg', href: 'https://berriz.in/ko', width: 24, height: 24 },
    ],
    projects: [
      {
        name: 'Berriz 글로벌 팬 플랫폼 · Community · Shop · Accounts · DeepLink · Live Player · Agents',
        bullets: [
          '서비스 초기 구축 단계부터 참여해 100만 유저 이상의 규모로 성장하는 과정에 기여했습니다.',
          'Universal Links · App Links · Custom Scheme을 활용한 딥링크 시스템(link.berriz.in)을 설계·구현했습니다. 폴백 처리와 SEO 지원으로, 링크 하나만 눌러도 앱이 있으면 앱 내부의 화면으로, 없으면 막힘없이 설치까지 이어지게 했습니다.',
          '웹뷰와 네이티브 컴포넌트 사이의 인터페이스를 다듬어 UX를 개선했습니다.',
          'Terraform으로 CloudFront · Lambda · S3 기반 AWS 아키텍처를 프로비저닝하고 운영했습니다.',
          '커밋/PR 처리, 문서 요약, 태스크 생성 등 반복 작업을 자동화하는 Berriz 에이전트를 개발했습니다.',
        ],
      },
      {
        name: "Debut's Plan 실시간 투표 서비스",
        link: '/debutsplan',
        bullets: [],
      },
    ],
  },
  {
    title: '토스뱅크',
    period: '2023.09 ~ 2024.04',
    role: 'Software Engineer',
    link: '/tossbank',
    logos: [
      { src: '/images/tossbank/Toss_Symbol_Primary.png', href: 'https://www.tossbank.com/', width: 24, height: 24 },
    ],
    projects: [
      {
        name: 'Housing Loan Squad',
        bullets: [
          'Loan Tribe의 대출 심사·승인 프로세스를 간소화하기 위해 설계된 LUMOS(Loan Universal Management Operating System)를 개발했습니다.',
          '알림 서비스를 구현해 특정 문서 심사 프로세스 시간을 50% 단축했습니다.',
          '낙관적 업데이트(optimistic update)를 적용해 UI 반응성과 사용자 경험을 개선했습니다.',
          '런타임 검증의 중요성을 강조하고 Zod를 도입해 타입 안전한 애플리케이션을 개발했습니다.',
        ],
      },
    ],
  },
  {
    title: 'SW Maestro',
    period: '2022.04 ~ 2022.12',
    role: 'Software Engineer',
    projects: [
      {
        name: '',
        bullets: ['MOZI 서비스를 개발했으며, 13기를 빛낸 13인의 연수생에 선정되었습니다.'],
      },
    ],
  },
]

const skills = [
  '모던 프론트엔드 기술 스택을 빠르게 습득하여 적용할 수 있는 유연함과 변하지 않는 부분을 깊이 있게 공부하는 단단함을 가지고 있습니다.',
  '프론트엔드에서 상태 관리에 대해 이해하며 적절한 패턴 적용 및 적절한 라이브러리를 선택할 수 있습니다.',
  '브라우저의 구조와 특성을 이해하며, Core Web Vitals를 고려하여 프로젝트에 적절한 렌더링 패턴을 적용할 수 있습니다.',
  'React, Next.js 생태계에 관심이 많고 더 나은 개발 방법에 대해 끊임없이 고민합니다.',
  'Node.js, Nest.js를 사용하여 서버를 구축하고, AWS 서비스들을 사용하여 애플리케이션을 배포 및 운영해본 경험이 있습니다.',
  'Github Action, CodeDeploy등을 사용하여 CI/CD 환경을 구축하여 코드의 안정성 및 신뢰성을 높일 수 있습니다.',
]

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '이현진 (Hyunjin Lee)',
  alternateName: 'Hyunjin Lee',
  url: siteMetadata.siteUrl,
  image: `${siteMetadata.siteUrl}/images/hyunjin/hyunjin.jpg`,
  jobTitle: 'Software Engineer',
  email: `mailto:${siteMetadata.email}`,
  worksFor: { '@type': 'Organization', name: 'Kakao Entertainment' },
  sameAs: [siteMetadata.github, siteMetadata.linkedin, siteMetadata.youtube].filter(Boolean),
}
---

<Base
  canonical={siteMetadata.siteUrl}
  hreflang={{ ko: siteMetadata.siteUrl, en: `${siteMetadata.siteUrl}/en`, xDefault: `${siteMetadata.siteUrl}/en` }}
  ogUrl={false}
  locale="ko"
>
  <div class="divide-y divide-gray-200 dark:divide-gray-700">
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <div class="container md:mt-5">
      <header class="mb-8">
        <div class="flex flex-col items-start gap-8 md:flex-row">
          <div class="relative flex-shrink-0 mx-auto overflow-hidden rounded-full w-50 h-50 md:w-50 md:h-50 md:mx-0">
            <img src="/images/hyunjin/hyunjin.jpg" alt="이현진" class="absolute inset-0 h-full w-full object-cover" />
          </div>
          <div class="flex-1 text-center md:text-left">
            <h1 class="mb-2 text-3xl font-bold text-gray-900 dark:text-gray-100">이현진 (Hyunjin Lee)</h1>
            <p class="mb-6 text-lg text-gray-600 md:text-xl dark:text-gray-400">Software Engineer</p>

            <div class="mb-6 space-y-3 text-base text-gray-700 dark:text-gray-300">
              <p>웹 페이지 위에 내 생각을 표현할 수 있다는 것에 매력을 느껴서 프론트엔드 개발을 좋아하게 되었습니다.</p>
              <p>
                서비스를 만들어가는 과정에서 동료와 토론하고 배운 내용을 공유하는 것을 즐깁니다. 또한 하드스킬과
                소프트스킬을 기르는데 있어서 꾸준함을 가지고 있고 새로운 도전을 통해 성장하고자 노력합니다.
              </p>
            </div>

            <div class="flex flex-wrap justify-center gap-3 text-base md:gap-4 md:justify-start">
              <span class="text-gray-600 dark:text-gray-400">{siteMetadata.email}</span>
              <span class="text-gray-400 dark:text-gray-600">·</span>
              <Link
                href={siteMetadata.github}
                target="_blank"
                rel="noopener noreferrer"
                class="transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
              >
                GitHub
              </Link>
              <span class="text-gray-400 dark:text-gray-600">·</span>
              <Link
                href={siteMetadata.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
              >
                LinkedIn
              </Link>
            </div>
          </div>
        </div>
      </header>

      <section class="mb-10">
        <h2 class="pb-2 mb-8 text-2xl font-bold text-gray-900 border-b-2 border-gray-200 md:text-3xl dark:text-gray-100 dark:border-gray-700">
          Work Experience
        </h2>
        <div class="space-y-8">
          {
            experiences.map((exp) => (
              <div class="group">
                <div class="flex flex-col gap-2 mb-2 sm:flex-row sm:justify-between sm:items-start">
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      {exp.link ? (
                        <Link
                          href={exp.link}
                          {...(exp.link.startsWith('/') ? {} : { target: '_blank', rel: 'noopener noreferrer' })}
                          class="text-lg font-semibold text-gray-900 transition-colors md:text-xl dark:text-gray-100 hover:text-primary-500 dark:hover:text-primary-400"
                        >
                          {exp.title}
                        </Link>
                      ) : (
                        <h3 class="text-lg font-semibold text-gray-900 md:text-xl dark:text-gray-100">{exp.title}</h3>
                      )}
                      {exp.logos?.map((logo) => (
                        <Link href={logo.href} target="_blank" rel="noopener noreferrer">
                          <img
                            src={logo.src}
                            alt=""
                            width={logo.width}
                            height={logo.height}
                            style={`height:${logo.height}px;width:${logo.width}px`}
                            class={`object-contain ${logo.darkInvert ? 'dark:invert' : ''}`}
                          />
                        </Link>
                      ))}
                    </div>
                    <p class="mt-1 text-sm text-gray-600 md:text-base dark:text-gray-400">{exp.role}</p>
                  </div>
                  <span class="text-sm text-gray-500 whitespace-nowrap dark:text-gray-500">{exp.period}</span>
                </div>
                <div class="mt-3 space-y-4">
                  {exp.projects.map((project) => (
                    <div>
                      {project.name &&
                        (project.link ? (
                          <Link
                            href={project.link}
                            class="text-sm font-medium text-gray-800 break-keep md:text-base dark:text-gray-200 transition-colors hover:text-primary-500 dark:hover:text-primary-400"
                          >
                            {project.name}
                          </Link>
                        ) : (
                          <p class="text-sm font-medium text-gray-800 break-keep md:text-base dark:text-gray-200">{project.name}</p>
                        ))}
                      <ul class={`${project.name ? 'mt-2' : ''} space-y-1.5`}>
                        {project.bullets.map((bullet) => (
                          <li class="text-sm text-gray-700 dark:text-gray-300 break-keep pl-5 relative before:content-['–'] before:absolute before:left-0 before:text-primary-500">
                            {bullet}
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="mb-10">
        <h2 class="pb-2 mb-8 text-2xl font-bold text-gray-900 border-b-2 border-gray-200 md:text-3xl dark:text-gray-100 dark:border-gray-700">
          Open Source
        </h2>
        <div class="group">
          <div class="flex flex-col gap-2 mb-2 sm:flex-row sm:justify-between sm:items-start">
            <div class="flex-1">
              <Link
                href="https://github.com/vercel-labs/agent-browser"
                target="_blank"
                rel="noopener noreferrer"
                class="text-lg font-semibold text-gray-900 transition-colors md:text-xl dark:text-gray-100 hover:text-primary-500 dark:hover:text-primary-400"
              >
                agent-browser
              </Link>
              <p class="mt-1 text-sm text-gray-600 md:text-base dark:text-gray-400">
                vercel-labs ·{' '}
                <Link
                  href="https://github.com/search?q=repo%3Avercel-labs%2Fagent-browser+is%3Apr+is%3Amerged+author%3Ajin-2-kakaoent+author%3Ahyunjinee&type=pullrequests"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
                >
                  28 PRs merged
                </Link>{' '}
                · Rust / TypeScript
              </p>
            </div>
            <div class="flex flex-col gap-1 mt-1 sm:mt-0 sm:items-end">
              <span class="text-sm text-gray-500 whitespace-nowrap dark:text-gray-500">2026.03 ~</span>
              <Link
                href="/blog/agent-browser"
                class="text-sm transition-colors whitespace-nowrap text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
              >
                블로그
              </Link>
            </div>
          </div>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="pb-2 mb-8 text-2xl font-bold text-gray-900 border-b-2 border-gray-200 md:text-3xl dark:text-gray-100 dark:border-gray-700">
          Skills
        </h2>
        <ul class="space-y-4">
          {
            skills.map((skill) => (
              <li class="text-sm md:text-base text-gray-700 dark:text-gray-300 pl-6 relative before:content-['•'] before:absolute before:left-0 before:text-primary-500">
                {skill}
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2 class="pb-2 mb-8 text-2xl font-bold text-gray-900 border-b-2 border-gray-200 md:text-3xl dark:text-gray-100 dark:border-gray-700">
          News
        </h2>
        <div class="space-y-4">
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-4">
            <span class="flex-shrink-0 text-[14px] font-medium text-gray-500 md:text-base dark:text-gray-500 sm:w-20">08/2025</span>
            <div class="flex-1">
              <p class="text-[14px] text-gray-700 md:text-[16px] dark:text-gray-300">
                <Link href="https://www.kakaotechcampus.com/" class='"transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"'>
                  카카오 테크 캠퍼스
                </Link>
                &nbsp;3기 FE 멘토
              </p>
            </div>
          </div>
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-4">
            <span class="flex-shrink-0 text-[14px] font-medium text-gray-500 md:text-[16px] dark:text-gray-500 sm:w-20">03/2023</span>
            <div class="flex-1">
              <p class="text-[14px] text-gray-700 md:text-[16px] dark:text-gray-300">
                SI Analytics Frontend Engineer(대학교 산학 협력 인턴) Ovision 서비스 개발
              </p>
            </div>
          </div>
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-4">
            <span class="flex-shrink-0 text-[14px] font-medium text-gray-500 md:text-[16px] dark:text-gray-500 sm:w-20">02/2023</span>
            <div class="flex-1">
              <p class="text-[14px] text-gray-700 md:text-[16px] dark:text-gray-300">
                <Link
                  href="https://www.dbpia.co.kr/Journal/articleDetail?nodeId=NODE11229679"
                  class='"transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"'
                >
                  인공지능 스피커를 활용한 복약 지원 시스템의 설계 및 구현
                </Link>
                (한국 HCI 학회, 졸업 논문)
              </p>
            </div>
          </div>
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-4">
            <span class="flex-shrink-0 text-[14px] font-medium text-gray-500 md:text-[16px] dark:text-gray-500 sm:w-20">10/2022</span>
            <div class="flex-1">
              <p class="text-[14px] text-gray-700 md:text-[16px] dark:text-gray-300">
                엘리스 SW 트랙 3기 실습 코치
                <Link href="/talks/asynchronous-javascript" class='"transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"'>
                  JavaScript, TypeScript 강의
                </Link>
                (수강생 72명 대상 4.49/5 평점)
              </p>
            </div>
          </div>
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-4">
            <span class="flex-shrink-0 text-[14px] font-medium text-gray-500 md:text-[16px] dark:text-gray-500 sm:w-20">04/2022</span>
            <div class="flex-1">
              <p class="text-[14px] text-gray-700 md:text-[16px] dark:text-gray-300">
                소프트웨어 마에스트로 13기 연수생(MOZI 서비스 개발, 13기를 빛낸 13인의 연수생)
              </p>
            </div>
          </div>
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-4">
            <span class="flex-shrink-0 text-[14px] font-medium text-gray-500 md:text-[16px] dark:text-gray-500 sm:w-20">07/2021</span>
            <div class="flex-1">
              <p class="text-[14px] text-gray-700 md:text-[16px] dark:text-gray-300">
                1인 가구 중심 부동산 플랫폼{' '}
                <Link href="/bclguide" class='"transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"'>
                  방슐랭 가이드
                </Link>
                (창업 동아리, 1500+ 유저, 98건 직거래 달성)
              </p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</Base>
