---
// app/[locale]/blog/page/[page]/page.tsx 이식 (ko). en판은 src/pages/en/blog/page/[page].astro.
// metadata export가 원본에 아예 없어 canonical/hreflang/title 전부 기본값(Base 폴백) 그대로 둔다.
// biome-ignore-all lint/correctness/noUnusedImports: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
// biome-ignore-all lint/correctness/noUnusedVariables: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
import Base from '../../../layouts/Base.astro'
import ListWithTags from '../../../layouts/ListWithTags.astro'
import { postsForLocale } from '../../../lib/posts'

// ponytail: Astro는 getStaticPaths를 모듈 스코프로 끌어올려 컴포넌트 본문의 top-level const에
// 접근할 수 없다 — 상수를 함수 안에서 각각 선언한다(공유 모듈로 뺄 만큼 복잡하지 않음).
export async function getStaticPaths() {
  const POSTS_PER_PAGE = 5
  const posts = await postsForLocale('ko')
  const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE))
  return Array.from({ length: totalPages }, (_, i) => ({ params: { page: String(i + 1) } }))
}

const POSTS_PER_PAGE = 5
const posts = await postsForLocale('ko')
const pageNumber = Number(Astro.params.page)
const initialDisplayPosts = posts.slice(POSTS_PER_PAGE * (pageNumber - 1), POSTS_PER_PAGE * pageNumber)
const pagination = { currentPage: pageNumber, totalPages: Math.ceil(posts.length / POSTS_PER_PAGE) }
---

<Base locale="ko">
  <ListWithTags posts={initialDisplayPosts} title="All Posts" locale="ko" pagination={pagination} />
</Base>
