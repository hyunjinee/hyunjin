---
// app/[locale]/blog/[...slug]/page.tsx 이식 (ko, 무프리픽스). en판은 src/pages/en/blog/[...slug].astro.
// 런타임 redirect(legacy slug·반대 locale 안내, page.tsx:116-135)는 이식하지 않는다 — _redirects 소관.
// biome-ignore-all lint/correctness/noUnusedImports: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
// biome-ignore-all lint/correctness/noUnusedVariables: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
import { render } from 'astro:content'
import { mdxComponents } from '../../components/mdx'
import Base from '../../layouts/Base.astro'
import PostBanner from '../../layouts/PostBanner.astro'
import PostLayout from '../../layouts/PostLayout.astro'
import PostSimple from '../../layouts/PostSimple.astro'
import { type PostPageData, postPagesForLocale } from '../../lib/blogPost'

export async function getStaticPaths() {
  const pages = await postPagesForLocale('ko')
  return pages.map((data) => ({ params: { slug: data.slug }, props: { data } }))
}

const { data } = Astro.props as { data: PostPageData }
const { entry, authorDetails, canonical, hreflang, ogImage, publishedAt, modifiedAt, jsonLd } = data
const { Content } = await render(entry)

const layouts = { PostLayout, PostSimple, PostBanner }
const Layout = layouts[entry.data.layout ?? 'PostLayout']
---

<Base
  title={entry.data.title}
  description={entry.data.summary || null}
  canonical={canonical}
  hreflang={hreflang}
  ogImage={ogImage}
  locale="ko"
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={publishedAt} />
    <meta property="article:modified_time" content={modifiedAt} />
    {authorDetails.map((author) => <meta property="article:author" content={author.name} />)}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Layout data={data}>
    <Content components={mdxComponents} />
  </Layout>
</Base>
