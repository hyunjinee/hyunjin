---
// app/[locale]/(ko-only)/berriz/page.tsx 이식 — 사용자 워킹트리 WIP 반영판.
// (최초 포트는 HEAD 커밋 버전 기준이었으나, 이후 사용자가 승인한 워킹트리 수정(불릿 전면 개편,
// stats dl 블록 추가, 섹션 3개 신설)을 동일 파일에 반영했다. 원본 page.tsx는 사용자 소유라 수정하지 않음.)
// biome-ignore-all lint/correctness/noUnusedImports: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
// biome-ignore-all lint/correctness/noUnusedVariables: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
import siteMetadata from '../../data/siteMetadata.js'
import Link from '../components/Link.astro'
import Base from '../layouts/Base.astro'

type Section = {
  title: string
  bullets: string[]
}

const sections: Section[] = [
  {
    title: '계정 · 인증',
    bullets: [
      '멜론(Melon) 계정 양방향 연동을 구현했습니다. 인바운드와 아웃바운드 각각의 동의 플로우를 만들고, 연동 전 사전 체크로 중복 연동을 막았습니다.',
      '연동 정보 화면이 시각을 KST로 고정해 보여주고 있어서, 해외 유저는 자기가 언제 연동했는지 잘못 알고 있었습니다. 기기 타임존 기준으로 고쳤습니다.',
      '커뮤니티·커머스 앱에 흩어져 있던 계정 기능(로그인·회원가입·계정관리·본인인증·법정대리인 동의)을 accounts.berriz.in 전용 도메인으로 분리 이관했습니다. 6개 페이지를 별도 앱으로 옮기고, 도메인이 바뀔 때 화면이 깜빡이지 않도록 BerrizLink 컴포넌트로 같은 도메인은 SPA 전환, 다른 도메인은 하드 내비게이션으로 분기했습니다.',
      '회원가입 OTP 인증부터 탈퇴 후 재로그인까지 계정 핵심 플로우를 Cypress E2E로 자동화해서, 이관 중 회귀를 막았습니다.',
    ],
  },
  {
    title: '하이브리드 앱 · 웹뷰 브릿지',
    bullets: [
      '원탭 웹뷰 구조는 뒤로가기 검은 화면, 스크롤·상태 미보존, 헤더 중복처럼 "웹뷰인 게 티 나는" 문제가 쌓입니다. 탭별 웹뷰 + 스택 웹뷰 하이브리드로 가는 구조 개편을 직접 발제하고, PHASE1~5 로드맵과 웹↔앱 브릿지 스펙을 설계했습니다.',
      '리로드 없이 새로고침되는 Pull-to-Refresh 공통 컴포넌트를 만들었습니다. 6개 상태를 가진 상태머신으로 짜고, 빠르게 당길 때 새로고침이 누락되던 레이스 버그를 근본 수정했습니다. aria-live 상태 안내와 reduced-motion 대응 등 접근성도 설계했습니다.',
      '앱과 웹이 통화나 국가 설정을 따로 들고 있으면 같은 화면이 다르게 보입니다. 두 값을 동기화하는 setAppValues 인터페이스로 어디서 열어도 같은 화면이 보이게 했습니다.',
      'openScheme 기반 앱 내 네비게이션 분기와 Pull-to-Refresh 제어를 브릿지 규약으로 정의했습니다.',
      '플로팅 디버그 패널을 만들어서, 웹뷰 문제를 앱 빌드 없이 웹에서 바로 재현하고 테스트합니다.',
      '안드로이드 웹뷰가 닫힐 때 모달 상태가 같이 날아가는 문제를 고쳤습니다.',
      '안드로이드 웹뷰가 백그라운드에서 포그라운드로 돌아올 때 화면이 검게 변하는 블랙스크린은 절전모드가 원인이었습니다. 원인 분석 과정을 트러블슈팅 문서로 남겼습니다.',
    ],
  },
  {
    title: '라이브 스트리밍 플레이어 (AWS IVS)',
