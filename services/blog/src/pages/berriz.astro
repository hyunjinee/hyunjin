const stats: { value: string; label: string }[] = [
  { value: '약 23개월', label: '서비스 초기부터' },
  { value: '758건', label: '머지 PR' },
  { value: '2,450건', label: '코드 리뷰' },
  { value: '66건', label: '기술 문서' },
  { value: '7건', label: '스택 메이저 버전업' },
]

const techStack = [
  'TypeScript',
  'React',
  'Next.js (App Router)',
  'TanStack Query / Form',
  'next-intl',
  'Zod',
  'TailwindCSS · Emotion',
  'Turborepo (pnpm)',
  'zustand',
  'AWS IVS Player',
  'AWS Lambda · CloudFront',
  'Terraform',
  'GKE · Helm · ArgoCD',
  'Cloud Armor (WAF)',
  'GitHub Actions',
  'Sentry',
  'Storybook',
  'Vitest · Cypress · agent-browser',
  'LangChain',
  'Python',
]
---

<Base title="Berriz" ogTitle={`Berriz | ${siteMetadata.title}`} ogImage={`${siteMetadata.siteUrl}${siteMetadata.socialBanner}`} locale="ko">
  <div class="container md:mt-5">
    {/* Hero */}
    <header class="pb-8 mb-10 border-b border-gray-200 dark:border-gray-700">
      <h1 class="sr-only">Berriz</h1>
      <div class="flex gap-3 items-center mb-4">
        <img src="/images/kakaoentertainment/berriz_logo.svg" alt="Berriz" width="96" height="32" class="h-[30px] w-auto" />
        <span class="text-sm text-gray-400 dark:text-gray-600">·</span>
        <span class="text-sm text-gray-600 dark:text-gray-400">Kakao Entertainment · Frontend Engineer</span>
      </div>
      <p class="text-sm leading-7 text-gray-700 break-keep md:text-base dark:text-gray-300">
        글로벌 팬 플랫폼 <strong>Berriz</strong>의 프론트엔드를 서비스 초기 구축 단계부터 개발했습니다. 서비스는
        100만 유저를 넘는 규모로 글로벌 출시됐습니다. 계정 연동, 딥링크, 라이브 플레이어 등 한 일을 주제별로
        정리했습니다.
      </p>
      <dl class="grid grid-cols-2 gap-x-6 gap-y-4 mt-6 sm:grid-cols-5">
        {
          stats.map((s) => (
            <div>
              <dt class="text-xl font-bold text-gray-900 md:text-2xl dark:text-gray-100">{s.value}</dt>
              <dd class="mt-0.5 text-xs text-gray-500 md:text-sm dark:text-gray-400">{s.label}</dd>
            </div>
          ))
        }
      </dl>
      <div class="flex flex-wrap gap-3 items-center mt-6 text-sm md:gap-4">
        <a href="https://berriz.in/ko" target="_blank" rel="noopener noreferrer" class="transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400">
          berriz.in ↗
        </a>
        <span class="text-gray-400 dark:text-gray-600">·</span>
        <Link href="/kakaoent" class="transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400">
          이력 요약
        </Link>
        <span class="text-gray-400 dark:text-gray-600">·</span>
        <Link href="/blog/deeplink" class="transition-colors text-primary-500 hover:text-primary-600 dark:hover:text-primary-400">
          딥링크 기술 글
        </Link>
      </div>
    </header>

    {/* Contribution sections */}
    <section class="mb-12">
      <h2 class="pb-2 mb-8 text-2xl font-bold text-gray-900 border-b-2 border-gray-200 md:text-3xl dark:text-gray-100 dark:border-gray-700">
        기여 영역
      </h2>
      <div class="space-y-8">
        {
          sections.map((s) => (
            <div class="group">
              <div class="flex gap-3 items-baseline">
                <h3 class="flex-1 text-lg font-semibold text-gray-900 md:text-xl dark:text-gray-100">{s.title}</h3>
              </div>
              <ul class="mt-3 ml-8 space-y-2">
                {s.bullets.map((b) => (
                  <li class="text-sm md:text-base text-gray-700 dark:text-gray-300 pl-5 relative before:content-['–'] before:absolute before:left-0 before:text-primary-500">
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    {/* Tech stack */}
    <section class="mb-12">
      <h2 class="pb-2 mb-8 text-2xl font-bold text-gray-900 border-b-2 border-gray-200 md:text-3xl dark:text-gray-100 dark:border-gray-700">
        기술 스택
      </h2>
      <div class="flex flex-wrap gap-2">
        {
          techStack.map((t) => (
            <span class="px-3 py-1 text-sm text-gray-700 rounded-full border border-gray-200 dark:text-gray-300 dark:border-gray-700">
              {t}
            </span>
          ))
        }
      </div>
    </section>
  </div>
</Base>
