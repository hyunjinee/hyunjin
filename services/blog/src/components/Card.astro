---
// components/Card.tsx 이식 — projects.astro 전용
// biome-ignore-all lint/correctness/noUnusedImports: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
// biome-ignore-all lint/correctness/noUnusedVariables: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
import Link from './Link.astro'

interface Props {
  title: string
  description: string
  imgSrc?: string
  href?: string
}

const { title, description, imgSrc, href } = Astro.props
---

<div class:list={['md max-w-[544px] p-4 md:w-1/2']}>
  <div class:list={['overflow-hidden rounded-md border-2 border-gray-200 border-opacity-60 dark:border-gray-700', { 'h-full': imgSrc }]}>
    {
      imgSrc && (
        href ? (
          <Link href={href} aria-label={`Link to ${title}`}>
            <img alt={title} src={imgSrc} class="aspect-[16/9] w-full object-cover object-center" width="544" height="306" />
          </Link>
        ) : (
          <img alt={title} src={imgSrc} class="aspect-[16/9] w-full object-cover object-center" width="544" height="306" />
        )
      )
    }
    <div class="p-6">
      <h2 class="mb-3 text-2xl font-bold leading-8 tracking-tight">
        {href ? <Link href={href} aria-label={`Link to ${title}`}>{title}</Link> : title}
      </h2>
      <p class="mb-3 prose text-gray-500 max-w-none dark:text-gray-400">{description}</p>
      {
        href && (
          <Link href={href} class="text-base font-medium leading-6 text-primary-500 hover:text-primary-600 dark:hover:text-primary-400" aria-label={`Link to ${title}`}>
            Learn more &rarr;
          </Link>
        )
      }
    </div>
  </div>
</div>
