---
// app/[locale]/Main.tsx 이식. /blog, /en/blog(비페이지네이션 전체 목록)가 소비한다.
// React 19 ViewTransition → CSS view-transition-name(Task 3의 PostBanner.astro와 동일 규칙).
// biome-ignore-all lint/correctness/noUnusedImports: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
// biome-ignore-all lint/correctness/noUnusedVariables: biome이 .astro 템플릿(--- 아래)을 파싱하지 않아 오탐
import siteMetadata from '../../data/siteMetadata.js'
import { postUrl } from '../lib/locale'
import type { Entry } from '../lib/posts'
import { entryLocale, entrySlug } from '../lib/posts'
import Link from './Link.astro'
import Tag from './Tag.astro'

const MAX_DISPLAY = 50
const dateOptions: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' }

interface Props {
  posts: Entry[]
}

const { posts } = Astro.props
---

<div class="divide-y divide-gray-200 dark:divide-gray-700">
  <ul class="divide-y divide-gray-200 dark:divide-gray-700">
    {!posts.length && 'No posts found.'}
    {
      posts.slice(0, MAX_DISPLAY).map((post) => {
        const slug = entrySlug(post)
        const locale = entryLocale(post)
        const href = postUrl(locale, slug)
        const { date, title, summary, tags } = post.data
        return (
          <li class="py-5">
            <article>
              <div class="space-y-2 xl:grid xl:grid-cols-4 xl:items-baseline xl:space-y-0">
                <dl>
                  <dt class="sr-only">Published on</dt>
                  <dd class="text-base font-medium leading-6 text-gray-500 dark:text-gray-400">
                    <time datetime={date.toISOString()}>{date.toLocaleDateString(siteMetadata.locale, dateOptions)}</time>
                  </dd>
                </dl>
                <div class="space-y-5 xl:col-span-3">
                  <div class="space-y-6">
                    <div>
                      <h2 class="text-2xl font-bold tracking-tight leading-8">
                        <Link href={href} class="text-gray-900 dark:text-gray-100">
                          <span style={`view-transition-name: title-${slug}`}>{title}</span>
                        </Link>
                      </h2>
                      <div class="flex flex-wrap">
                        {tags.map((tag) => (
                          <Tag text={tag} locale={locale} />
                        ))}
                      </div>
                    </div>
                    <div class="max-w-none text-gray-500 prose dark:text-gray-400">{summary}</div>
                  </div>
                  <div class="text-base font-medium leading-6">
                    <Link href={href} class="text-primary-500 hover:text-primary-600 dark:hover:text-primary-400" aria-label={`Read more: "${title}"`}>
                      Read more &rarr;
                    </Link>
                  </div>
                </div>
              </div>
            </article>
          </li>
        )
      })
    }
  </ul>
</div>
