{
  "name": "@hyunjin/blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "validate": "node ./scripts/validate-i18n.mjs",
    "build": "node ./scripts/validate-i18n.mjs && node ./scripts/generate-og.mjs && node ./scripts/build-search-index.mjs && astro build && node ./scripts/rss.mjs && node ./scripts/verify-dist.mjs",
    "build:cf": "pnpm build",
    "deploy:cf": "pnpm build && wrangler deploy",
    "preview:cf": "pnpm build && wrangler dev",
    "lint:biome": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@excalidraw/excalidraw": "^0.18.1",
    "@headlessui/react": "2.2.9",
    "@tailwindcss/forms": "0.5.7",
    "@tailwindcss/postcss": "4.1.1",
    "@tailwindcss/typography": "0.5.19",
    "body-scroll-lock": "4.0.0-beta.0",
    "esbuild": "0.27.2",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.2",
    "hast-util-from-html-isomorphic": "2.0.0",
    "image-size": "1.0.0",
    "katex": "0.16.27",
    "kbar": "0.1.0-beta.45",
    "mermaid": "^11.14.0",
    "notion-types": "^7.10.0",
    "pdfjs-dist": "5.4.530",
    "postcss": "8.4.24",
    "prismjs": "^1.30.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-notion-x": "^7.10.0",
    "react-pdf": "^10.3.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-preset-minify": "7.0.0",
    "rehype-prism-plus": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-gfm": "^4.0.0",
    "remark-github-blockquote-alert": "^1.2.1",
    "remark-math": "^6.0.0",
    "sharp": "0.34.1",
    "tailwindcss": "4.1.1",
    "unist-util-visit": "^5.0.0",
    "vibetip": "^0.5.1",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@biomejs/biome": "2.3.12",
    "@chromatic-com/storybook": "3.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "@storybook/addon-essentials": "8.5.3",
    "@storybook/addon-interactions": "8.5.3",
    "@storybook/addon-onboarding": "8.5.3",
    "@storybook/blocks": "8.5.3",
    "@storybook/nextjs": "8.5.3",
    "@storybook/react": "8.5.3",
    "@storybook/test": "8.5.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/mdx": "2.0.12",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "astro": "^7.0.7",
    "baseline-browser-mapping": "2.9.11",
    "eslint-plugin-storybook": "0.11.2",
    "notion-client": "^7.10.0",
    "satori": "^0.26.0",
    "storybook": "8.5.3",
    "typescript": "5.9.3",
    "wrangler": "^4.110.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "biome check --write"
    ]
  }
}
