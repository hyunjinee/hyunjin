{
  "name": "@hyunjin/blog",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "next dev",
    "dev": "cross-env INIT_CWD=$PWD concurrently \"contentlayer2 dev\" \"next dev\"",
    "dev:no-turbo": "cross-env INIT_CWD=$PWD next dev --turbo=false",
    "validate": "node ./scripts/validate-i18n.mjs",
    "build": "cross-env INIT_CWD=$PWD contentlayer2 build && node ./scripts/validate-i18n.mjs && node ./scripts/generate-og.mjs && cross-env INIT_CWD=$PWD next build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "serve": "next start",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir app --dir components --dir lib --dir layouts --dir scripts",
    "lint:biome": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@excalidraw/excalidraw": "^0.18.1",
    "@formatjs/intl-localematcher": "^0.8.12",
    "@headlessui/react": "2.2.9",
    "@mdx-js/loader": "3.1.1",
    "@next/bundle-analyzer": "16.1.1",
    "@next/mdx": "16.1.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/forms": "0.5.7",
    "@tailwindcss/postcss": "4.1.1",
    "@tailwindcss/typography": "0.5.19",
    "body-scroll-lock": "4.0.0-beta.0",
    "contentlayer2": "0.5.3",
    "esbuild": "0.27.2",
    "framer-motion": "12.23.26",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.2",
    "hast-util-from-html-isomorphic": "2.0.0",
    "image-size": "1.0.0",
    "katex": "0.16.27",
    "mermaid": "^11.14.0",
    "negotiator": "^1.0.0",
    "next": "16.1.1",
    "next-contentlayer2": "0.5.3",
    "next-themes": "0.4.4",
    "notion-types": "^7.10.0",
    "pdfjs-dist": "5.4.530",
    "pliny": "0.4.0",
    "postcss": "8.4.24",
    "prismjs": "^1.30.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-notion-x": "^7.10.0",
    "react-pdf": "^10.3.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-preset-minify": "7.0.0",
    "rehype-prism-plus": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-gfm": "^4.0.0",
    "remark-github-blockquote-alert": "^1.2.1",
    "remark-math": "^6.0.0",
    "sharp": "0.34.1",
    "sugar-high": "^0.9.5",
    "tailwindcss": "4.1.1",
    "unist-util-visit": "^5.0.0",
    "vibetip": "^0.5.1",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@chromatic-com/storybook": "3.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "@storybook/addon-essentials": "8.5.3",
    "@storybook/addon-interactions": "8.5.3",
    "@storybook/addon-onboarding": "8.5.3",
    "@storybook/blocks": "8.5.3",
    "@storybook/nextjs": "8.5.3",
    "@storybook/react": "8.5.3",
    "@storybook/test": "8.5.3",
    "@svgr/webpack": "8.0.1",
    "@types/mdx": "2.0.12",
    "@types/negotiator": "^0.6.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "6.1.0",
    "@typescript-eslint/parser": "6.1.0",
    "babel-plugin-react-compiler": "19.0.0-beta-ebf51a3-20250411",
    "baseline-browser-mapping": "2.9.11",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "eslint": "8.45.0",
    "eslint-config-next": "16.1.1",
    "eslint-plugin-storybook": "0.11.2",
    "notion-client": "^7.10.0",
    "satori": "^0.26.0",
    "storybook": "8.5.3",
    "typescript": "5.9.3",
    "wrangler": "^4.110.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "biome check --write"
    ]
  }
}
